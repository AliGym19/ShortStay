# Xero app credentials — developer.xero.com/myapps (app type must be "Web app";
# Mobile/PWA apps are PKCE-only and won't work with this flow).
# Register this redirect URI on the app, character-exact:
#   http://localhost:3000/api/auth/callback
# Copy this file to .env and fill in. NEVER commit .env.
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=

# OpenRouter — backs lib/llm.ts (issue classifier + action stager).
# Key from openrouter.ai/keys.
OPENROUTER_API_KEY=

# Supabase — ShortStay's own storage (forecast cache, triage queue), NOT a
# Xero API proxy: Supabase has no connector into api.xero.com. Xero data
# still flows only through lib/xero.ts.
SUPABASE_PROJECT_ID=
SUPABASE_URL=
SUPABASE_DB_PASSWORD=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
