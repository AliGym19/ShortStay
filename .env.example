# Xero app credentials — developer.xero.com/myapps (app type must be "Web app";
# Mobile/PWA apps are PKCE-only and won't work with this flow).
# Register this redirect URI on the app, character-exact:
#   http://localhost:3000/api/auth/callback
# Copy this file to .env and fill in. NEVER commit .env.
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
